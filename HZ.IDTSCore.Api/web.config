<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<configSections>
		<section name="ActiveReports13" type="GrapeCity.ActiveReports.Web.ActiveReportsSettingsSection" />
	</configSections>
	<system.webServer>
		<directoryBrowse enabled="true" />
	</system.webServer>
	<ActiveReports13>
		<WebService reportsFolder="~/" assemblyFolder="~/" />
	</ActiveReports13>
	<location path="." inheritInChildApplications="false">
		<system.webServer>
			<handlers>
				<add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
			</handlers>
			<aspNetCore processPath="bin\Debug\netcoreapp3.1\HZ.IDTSCore.Api.exe" stdoutLogEnabled="false" hostingModel="InProcess" arguments="">
				<environmentVariables>
					<environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Development" />
				</environmentVariables>
			</aspNetCore>
		</system.webServer>
		<system.webServer>
			<security>
				<requestFiltering>
					<requestLimits maxAllowedContentLength="104857600" />
				</requestFiltering>
			</security>
		</system.webServer>
	</location>
</configuration>